# OS
.DS_Store
.AppleDouble
.LSOverride
._*

# Roblox build outputs
*.rbxl
*.rbxlx
*.rbxm
*.rbxmx
build/
dist/

# Rokit
!rokit.toml

# Wally
Packages/

# Editor
.vscode/
.idea/
*.swp

# Secrets
.env
secrets.json
api-keys.json

# Mantle state
.mantle-state.yml

# Wrangler local build/preview cache (telemetry Worker dev artifacts)
tools/telemetry-worker/.wrangler/
.wrangler/

# Logs
*.log

# Local debug scratch (top-level only — keeps scripts/debug/ dev tool tracked)
/debug/
# Runtime debug capture artifacts (screenshots, bug-report dirs) — not the toolkit
scripts/debug/captures/

# Claude Code per-machine state (committed: .claude/settings.json)
.claude/settings.local.json

# Claude Code worktrees (per-machine, not part of project)
.claude/worktrees/

# Per-user private skill bundle (Anthropic Cowork-style); never project-tracked
.agents/

# Telemetry config — generated at publish time from .env (BB_TELEMETRY_*).
# Contains the live ingest key, never commit.
src/ServerScriptService/TelemetryConfig.luau

# Gamepass config — generated at publish time from .env (BB_TINKERER_PASS_ID).
# Not secret, but regenerated every build so committing it would churn.
src/ServerScriptService/GamepassConfig.luau

# Chat history mirror — regenerable from ~/.claude/projects/<encoded>/<id>.jsonl
# via scripts/history/export_history.py. Don't commit (it would churn every turn).
Bloom&Burgle_ChatHistory.md
scripts/history/.last_uuid
scripts/history/.rlm_logs/

# Python bytecode
__pycache__/
*.pyc
