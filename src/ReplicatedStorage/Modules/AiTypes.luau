--!strict
-- AiTypes — shared type definitions for the Seed AI system.
--
-- BAB-LIVE-FEATURES Block 1 (2026-05-11). See
-- Bloom&Burgle_Live_Features_Design_2026-05-11.md §1.
--
-- This module is in ReplicatedStorage/Modules so client + server (across
-- all 3 places) see the same types. The actual AI implementation lives
-- server-side in src/ServerScriptService/AiAgents/.

local M = {}

-- ── Archetype: the agent's behavior personality ──────────────────────
-- v1 ships 3 of the 5 archetypes described in the design doc:
--   • Greeter — approaches new players, chats, points to plot
--   • Trader — lingers near merchant stalls (Marketplace stretch, not v1)
--   • Silent — quietly grows their plot; background activity only
-- Rival + Quester are deferred to Block 4 (raid) + a future quest system.
export type Archetype = "Greeter" | "Trader" | "Silent"

-- ── Class: same as player classes; drives rig accessories + critter pref
-- See ClassData.luau for the canonical player-side class list.
export type AiClass = "Knight" | "Tinkerer" | "SkyPirate" | "Alchemist" | "Hexer"

-- ── Per-agent runtime state (kept on the AgentBrain) ─────────────────
-- AgentState is a coarse-grained state machine. See AgentBrain.luau for
-- the transitions.
export type AgentState =
	"idle"
	| "walking_to_planter"
	| "planting"
	| "waiting"
	| "walking_to_ripe"
	| "harvesting"
	| "wander"

-- Stable identifier per (server job, agent slot). Generated by the
-- spawner; survives the lifetime of the server job. AI is server-local
-- in v1, so this id never escapes the server.
export type AgentId = string

-- Full agent descriptor. Owned by AgentBrain; passed by reference.
-- NOT exported to client (AI is server-side; clients see only the rigs).
export type AgentDescriptor = {
	id: AgentId,
	archetype: Archetype,
	class: AiClass,
	-- Display name format: "<Adjective> · <Class>" (e.g. "Coghand · Tinkerer").
	-- The dot-separator (·, U+00B7) is the visual signal that this is not
	-- a real Roblox username — those don't contain that character. Per
	-- the locked 2026-05-11 disclosure decision.
	name: string,
	-- Workspace anchor part for this agent's mini-plot. The agent's
	-- humanoid lives on/near this plot; planters are children of it.
	plotPart: BasePart,
	-- The agent's humanoid Model (parented to Workspace). Lives the
	-- lifetime of the server.
	humanoid: Model,
	-- The agent's planters on its mini-plot (4 per agent in v1).
	planters: { BasePart },
}

return M
