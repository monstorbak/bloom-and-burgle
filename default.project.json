{
  "name": "Bloom & Burgle",
  "tree": {
    "$className": "DataModel",

    "ReplicatedStorage": {
      "$className": "ReplicatedStorage",
      "Modules": {
        "$className": "Folder",
        "$path": "src/ReplicatedStorage/Modules"
      },
      "RemoteEvents": {
        "$className": "Folder",
        "$path": "src/ReplicatedStorage/RemoteEvents"
      }
    },

    "ServerScriptService": {
      "$className": "ServerScriptService",
      "$path": "src/ServerScriptService"
    },

    "ServerStorage": {
      "$className": "ServerStorage",
      "$path": "src/ServerStorage"
    },

    "StarterPlayer": {
      "$className": "StarterPlayer",
      "StarterPlayerScripts": {
        "$className": "StarterPlayerScripts",
        "$path": "src/StarterPlayerScripts"
      }
    },

    "StarterGui": {
      "$className": "StarterGui",
      "$path": "src/StarterGui"
    },

    "Workspace": {
      "$className": "Workspace",
      "$properties": {
        "FilteringEnabled": true
      },
      "Baseplate": {
        "$className": "Part",
        "$properties": {
          "Anchored": true,
          "Locked": true,
          "Size": [4096, 4, 4096],
          "Position": [0, -2, 0],
          "Material": "Grass",
          "Color": [0.36, 0.62, 0.31]
        }
      },
      "TownSquare": {
        "$path": "src/Workspace/TownSquare.model.json"
      }
    },

    "Lighting": {
      "$className": "Lighting",
      "$properties": {
        "Brightness": 2.5,
        "ClockTime": 14,
        "FogEnd": 1500,
        "GlobalShadows": true,
        "OutdoorAmbient": [0.5, 0.5, 0.5],
        "Technology": "Future"
      }
    },

    "SoundService": {
      "$className": "SoundService"
    },

    "HttpService": {
      "$className": "HttpService",
      "$properties": {
        "HttpEnabled": true
      }
    },

    "Players": {
      "$className": "Players",
      "$properties": {
        "RespawnTime": 3
      }
    }
  }
}
