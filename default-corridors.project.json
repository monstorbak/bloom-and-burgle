{
  "name": "Bloom & Burgle (Corridors)",
  "tree": {
    "$className": "DataModel",

    "ReplicatedStorage": {
      "$className": "ReplicatedStorage",
      "Modules": {
        "$path": "src/ReplicatedStorage/Modules"
      },
      "RemoteEvents": {
        "$path": "src/ReplicatedStorage/RemoteEvents"
      }
    },

    "ServerScriptService": {
      "$className": "ServerScriptService",
      "$path": "src-corridors/ServerScriptService",

      "Services":        { "$path": "src/ServerScriptService/Services.luau" },
      "RateLimiter":     { "$path": "src/ServerScriptService/RateLimiter.luau" },
      "Telemetry":       { "$path": "src/ServerScriptService/Telemetry.luau" },
      "TelemetryBoot":   { "$path": "src/ServerScriptService/TelemetryBoot.server.luau" },
      "TelemetryConfig": { "$path": "src/ServerScriptService/TelemetryConfig.luau", "$ignoreUnknownInstances": true },
      "DataStore":       { "$path": "src/ServerScriptService/DataStore.luau" }
    },

    "StarterPlayer": {
      "$className": "StarterPlayer",
      "StarterPlayerScripts": {
        "$className": "StarterPlayerScripts",
        "$path": "src-corridors/StarterPlayerScripts"
      }
    },

    "Workspace": {
      "$className": "Workspace",
      "$properties": {
        "FilteringEnabled": true
      },
      "Baseplate": {
        "$className": "Part",
        "$properties": {
          "Anchored": true,
          "Locked": true,
          "Size": [400, 4, 400],
          "Position": [0, -2, 0],
          "Material": "Slate",
          "Color": [0.12, 0.10, 0.10]
        }
      }
    },

    "Lighting": {
      "$className": "Lighting",
      "$properties": {
        "Brightness": 1.6,
        "ClockTime": 22,
        "FogEnd": 600,
        "FogStart": 50,
        "FogColor": [0.1, 0.08, 0.08],
        "GlobalShadows": true,
        "OutdoorAmbient": [0.3, 0.2, 0.2],
        "Technology": "Future"
      }
    },

    "SoundService": { "$className": "SoundService" },

    "HttpService": {
      "$className": "HttpService",
      "$properties": { "HttpEnabled": true }
    },

    "Players": {
      "$className": "Players",
      "$properties": { "RespawnTime": 3 }
    }
  }
}
